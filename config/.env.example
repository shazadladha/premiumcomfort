# TikTok Developer App Credentials
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI (must match what you configured in TikTok Developer Portal)
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/callback

# Local server port for OAuth callback
PORT=3000

# OpenAI API key for image generation (required for generate command)
OPENAI_API_KEY=your_openai_api_key_here

# Public site URL where generated images are hosted (GitHub Pages)
SITE_BASE_URL=https://premiumcomfort.uk
